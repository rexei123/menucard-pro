generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  locations Location[]
  users     User[]
  themes    Theme[]
  media     Media[]
  languages TenantLanguage[]
  allergens Allergen[]
  additives Additive[]
  tags      Tag[]
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  address   String?
  latitude  Float?
  longitude Float?
  timezone  String   @default("Europe/Vienna")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  translations LocationTranslation[]
  menus        Menu[]
  qrCodes      QRCode[]
  timeRules    TimeRule[]
  @@unique([tenantId, slug])
}

model LocationTranslation {
  id           String   @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  languageCode String
  name         String
  description  String?
  @@unique([locationId, languageCode])
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(EDITOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  EDITOR
}

model Menu {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  type        MenuType
  slug        String
  isActive    Boolean   @default(true)
  isArchived  Boolean   @default(false)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  translations MenuTranslation[]
  sections     MenuSection[]
  qrCodes      QRCode[]
  @@unique([locationId, slug])
}

enum MenuType {
  FOOD
  DRINKS
  WINE
  DAILY_SPECIAL
  SEASONAL
  BREAKFAST
  BAR
  SPA
  ROOM_SERVICE
  MINIBAR
  EVENT
}

model MenuTranslation {
  id           String @id @default(cuid())
  menuId       String
  menu         Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  languageCode String
  name         String
  description  String?
  footnote     String?
  @@unique([menuId, languageCode])
}

model MenuSection {
  id        String        @id @default(cuid())
  menuId    String
  menu      Menu          @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    MenuSection?  @relation("SectionTree", fields: [parentId], references: [id])
  children  MenuSection[] @relation("SectionTree")
  slug      String
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  icon      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  translations MenuSectionTranslation[]
  items        MenuItem[]
  @@unique([menuId, slug])
}

model MenuSectionTranslation {
  id           String      @id @default(cuid())
  sectionId    String
  section      MenuSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  languageCode String
  name         String
  description  String?
  @@unique([sectionId, languageCode])
}

model MenuItem {
  id            String         @id @default(cuid())
  sectionId     String
  section       MenuSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type          ItemType
  sku           String?
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  isSoldOut     Boolean        @default(false)
  isHighlight   Boolean        @default(false)
  highlightType HighlightType?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  translations   MenuItemTranslation[]
  priceVariants  PriceVariant[]
  allergens      MenuItemAllergen[]
  additives      MenuItemAdditive[]
  tags           MenuItemTag[]
  media          MenuItemMedia[]
  wineProfile    WineProfile?
  beverageDetail BeverageDetail?
  inventory      Inventory?
  pairings       Pairing[] @relation("PairingSource")
  pairedWith     Pairing[] @relation("PairingTarget")
}

enum ItemType {
  FOOD
  DRINK
  WINE
  OTHER
}

enum HighlightType {
  RECOMMENDATION
  NEW
  POPULAR
  PREMIUM
  SEASONAL
  CHEFS_CHOICE
}

model MenuItemTranslation {
  id                String   @id @default(cuid())
  menuItemId        String
  menuItem          MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  languageCode      String
  name              String
  shortDescription  String?
  longDescription   String?
  servingSuggestion String?
  internalNotes     String?
  @@unique([menuItemId, languageCode])
}

model PriceVariant {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  label      String?
  price      Decimal  @db.Decimal(10, 2)
  currency   String   @default("EUR")
  volume     String?
  sortOrder  Int      @default(0)
  isDefault  Boolean  @default(false)
  translations PriceVariantTranslation[]
}

model PriceVariantTranslation {
  id             String       @id @default(cuid())
  priceVariantId String
  priceVariant   PriceVariant @relation(fields: [priceVariantId], references: [id], onDelete: Cascade)
  languageCode   String
  label          String
  @@unique([priceVariantId, languageCode])
}

model Allergen {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  icon      String?
  sortOrder Int    @default(0)
  translations AllergenTranslation[]
  menuItems    MenuItemAllergen[]
  @@unique([tenantId, code])
}

model AllergenTranslation {
  id           String   @id @default(cuid())
  allergenId   String
  allergen     Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)
  languageCode String
  name         String
  description  String?
  @@unique([allergenId, languageCode])
}

model Additive {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  sortOrder Int    @default(0)
  translations AdditiveTranslation[]
  menuItems    MenuItemAdditive[]
  @@unique([tenantId, code])
}

model AdditiveTranslation {
  id           String   @id @default(cuid())
  additiveId   String
  additive     Additive @relation(fields: [additiveId], references: [id], onDelete: Cascade)
  languageCode String
  name         String
  @@unique([additiveId, languageCode])
}

model Tag {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug      String
  color     String?
  icon      String?
  translations TagTranslation[]
  menuItems    MenuItemTag[]
  @@unique([tenantId, slug])
}

model TagTranslation {
  id           String @id @default(cuid())
  tagId        String
  tag          Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  languageCode String
  name         String
  @@unique([tagId, languageCode])
}

model MenuItemAllergen {
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  allergenId String
  allergen   Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)
  @@id([menuItemId, allergenId])
}

model MenuItemAdditive {
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  additiveId String
  additive   Additive @relation(fields: [additiveId], references: [id], onDelete: Cascade)
  @@id([menuItemId, additiveId])
}

model MenuItemTag {
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([menuItemId, tagId])
}

model WineProfile {
  id             String    @id @default(cuid())
  menuItemId     String    @unique
  menuItem       MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  winery         String?
  vintage        Int?
  grapeVarieties String[]
  region         String?
  country        String?
  appellation    String?
  style          WineStyle?
  body           WineBody?
  sweetness      WineSweetness?
  bottleSize     String?   @default("0.75l")
  alcoholContent Float?
  servingTemp    String?
  tastingNotes   String?
  foodPairing    String?
  stockQuantity  Int?
  internalNotes  String?
}

enum WineStyle {
  RED
  WHITE
  ROSE
  SPARKLING
  DESSERT
  FORTIFIED
  ORANGE
  NATURAL
}

enum WineBody {
  LIGHT
  MEDIUM_LIGHT
  MEDIUM
  MEDIUM_FULL
  FULL
}

enum WineSweetness {
  DRY
  OFF_DRY
  MEDIUM_DRY
  MEDIUM_SWEET
  SWEET
}

model BeverageDetail {
  id             String            @id @default(cuid())
  menuItemId     String            @unique
  menuItem       MenuItem          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  brand          String?
  producer       String?
  category       BeverageCategory?
  alcoholContent Float?
  servingTemp    String?
  carbonated     Boolean           @default(false)
  origin         String?
}

enum BeverageCategory {
  BEER
  SPIRIT
  COCKTAIL
  SOFT_DRINK
  JUICE
  WATER
  HOT_DRINK
  SMOOTHIE
  OTHER
}

model Pairing {
  id           String      @id @default(cuid())
  sourceItemId String
  sourceItem   MenuItem    @relation("PairingSource", fields: [sourceItemId], references: [id], onDelete: Cascade)
  targetItemId String
  targetItem   MenuItem    @relation("PairingTarget", fields: [targetItemId], references: [id], onDelete: Cascade)
  type         PairingType @default(GOES_WELL)
  @@unique([sourceItemId, targetItemId])
}

enum PairingType {
  GOES_WELL
  RECOMMENDED
  SOMMELIER_CHOICE
}

model Media {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  filename     String
  mimeType     String
  url          String
  thumbnailUrl String?
  width        Int?
  height       Int?
  sizeBytes    Int?
  alt          String?
  createdAt    DateTime @default(now())
  menuItems    MenuItemMedia[]
}

model MenuItemMedia {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  mediaId    String
  media      Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
}

model QRCode {
  id           String   @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  menuId       String?
  menu         Menu?    @relation(fields: [menuId], references: [id])
  label        String?
  shortCode    String   @unique
  logoUrl      String?
  primaryColor String?  @default("#000000")
  bgColor      String?  @default("#FFFFFF")
  scans        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Theme {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String    @default("Default")
  isActive        Boolean   @default(true)
  primaryColor    String    @default("#1a1a1a")
  accentColor     String    @default("#8B6914")
  backgroundColor String    @default("#FAFAF8")
  textColor       String    @default("#1a1a1a")
  fontHeading     String    @default("Playfair Display")
  fontBody        String    @default("Source Sans 3")
  borderRadius    String    @default("8px")
  cardStyle       CardStyle @default(ELEGANT)
  logoUrl         String?
  backgroundImage String?
  customCSS       String?
}

enum CardStyle {
  ELEGANT
  MINIMAL
  CLASSIC
  MODERN
  RUSTIC
}

model TenantLanguage {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  name      String
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  @@unique([tenantId, code])
}

model TimeRule {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name       String
  menuId     String?
  startTime  String
  endTime    String
  daysOfWeek Int[]
  isActive   Boolean  @default(true)
}

model Inventory {
  id            String   @id @default(cuid())
  menuItemId    String   @unique
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity      Int      @default(0)
  minQuantity   Int      @default(0)
  purchasePrice Decimal? @db.Decimal(10, 2)
  unit          String?  @default("Stueck")
  autoSoldOut   Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model AnalyticsEvent {
  id         String    @id @default(cuid())
  tenantId   String
  locationId String?
  menuId     String?
  menuItemId String?
  qrCodeId   String?
  eventType  EventType
  language   String?
  userAgent  String?
  referrer   String?
  sessionId  String?
  createdAt  DateTime  @default(now())
  @@index([tenantId, createdAt])
  @@index([eventType, createdAt])
}

enum EventType {
  QR_SCAN
  PAGE_VIEW
  MENU_VIEW
  ITEM_VIEW
  SEARCH
  FILTER
  PDF_DOWNLOAD
  EMBED_VIEW
  CTA_CLICK
}
