// ─── Small UI helpers ───
function Label({ children }: { children: React.ReactNode }) {
  return <label className="block text-xs font-medium text-gray-500 mb-1">{children}</label>;
}
function ColorInput({ label, value, onChange }: { label: string; value: string; onChange: (v: string) => void }) {
  return (
    <div className="flex items-center gap-2">
      <input type="color" value={value || '#000000'} onChange={e => onChange(e.target.value)}
        className="h-8 w-8 cursor-pointer rounded border border-gray-300 p-0.5" />
      <div className="flex-1">
        <div className="text-xs text-gray-500">{label}</div>
        <input type="text" value={value || ''} onChange={e => onChange(e.target.value)}
          className="w-full text-xs font-mono border-b border-gray-200 py-0.5 outline-none focus:border-gray-400" />
      </div>
    </div>
  );
}
function SelectInput({ label, value, options, onChange }: { label: string; value: string; options: { label: string; value: string }[]; onChange: (v: string) => void }) {
  return (
    <div>
      <Label>{label}</Label>
      <select value={value} onChange={e => onChange(e.target.value)}
        className="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm outline-none focus:border-gray-400">
        {options.map(o => <option key={o.value} value={o.value}>{o.label}</option>)}
      </select>
    </div>
  );
}
function SliderInput({ label, value, min, max, step, unit, onChange }: { label: string; value: number; min: number; max: number; step?: number; unit?: string; onChange: (v: number) => void }) {
  return (
    <div>
      <div className="flex justify-between items-baseline">
        <Label>{label}</Label>
        <span className="text-xs text-gray-400 font-mono">{value}{unit || ''}</span>
      </div>
      <input type="range" min={min} max={max} step={step || 1} value={value} onChange={e => onChange(Number(e.target.value))}
        className="w-full"
        style={{ accentColor: 'var(--color-primary)' }} />
    </div>
  );
}
function Toggle({ label, checked, onChange }: { label: string; checked: boolean; onChange: (v: boolean) => void }) {
  return (
    <label className="flex items-center justify-between cursor-pointer py-1">
      <span className="text-sm text-gray-700">{label}</span>
      <button type="button" onClick={() => onChange(!checked)}
        className="relative inline-flex h-5 w-9 items-center rounded-full transition-colors"
        style={{ backgroundColor: checked ? PRIMARY : '#D1D5DB' }}>
        <span className="inline-block h-3.5 w-3.5 transform rounded-full bg-white transition-transform"
          style={{ transform: checked ? 'translateX(18px)' : 'translateX(2px)' }} />
      </button>
    </label>
  );
}
function ConfirmDialog({ open, title, message, confirmLabel, onConfirm, onCancel }: {
  open: boolean; title: string; message: string; confirmLabel: string;
  onConfirm: () => void; onCancel: () => void;
}) {
  if (!open) return null;
  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center">
      <div className="absolute inset-0 bg-black/40 backdrop-blur-sm" onClick={onCancel} />
      <div className="relative bg-white rounded-xl shadow-2xl max-w-md w-full mx-4 overflow-hidden">
        <div className="p-6">
          <div className="flex items-start gap-3">
            <div className="flex-shrink-0 w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center">
              <span className="material-symbols-outlined text-amber-600" style={{ fontSize: 20 }}>warning</span>
            </div>
            <div className="flex-1">
              <h3 className="text-base font-semibold text-gray-900">{title}</h3>
              <p className="mt-2 text-sm text-gray-600 leading-relaxed">{message}</p>
            </div>
          </div>
        </div>
        <div className="flex justify-end gap-2 bg-gray-50 px-6 py-3">
          <button onClick={onCancel} className="rounded-lg px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50">Abbrechen</button>
          <button onClick={onConfirm} className="rounded-lg px-4 py-2 text-sm font-medium text-white" style={{ backgroundColor: '#D97706' }}>{confirmLabel}</button>
        </div>
      </div>
    </div>
  );
}

// ─── API Adapter (mode-aware) ───
function useApi(props: Props) {
  return useMemo(() => {
    if (props.mode === 'template') {
      return {
        mode: 'template' as const,
        load: async () => {
          const res = await fetch(`/api/v1/design-templates/${props.templateId}`);
          if (!res.ok) throw new Error('Laden fehlgeschlagen');
          const data = await res.json();
          const t = data.template;
          const digital = (t.config?.digital) || {};
          const analog = (t.config?.analog) || {};
          return {
            digital,
            analog,
            overrides: digital,
            analogOverrides: analog,
            templateName: digital.template || t.baseType || 'elegant',
            customTemplates: [],
            meta: { name: t.name, baseType: t.baseType, type: t.type },
          };
        },
        save: async (patch: any) => {
          // patch: { digital?: {...}, baseType?, name?, customTemplates? }
          const body: any = {};
          if (patch.name !== undefined) body.name = patch.name;
          if (patch.baseType !== undefined) body.baseType = patch.baseType;
          if (patch.digital !== undefined || patch.analog !== undefined) {
            body.config = {};
            if (patch.digital !== undefined) body.config.digital = patch.digital;
            if (patch.analog !== undefined) body.config.analog = patch.analog;
          }
          const res = await fetch(`/api/v1/design-templates/${props.templateId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            throw new Error(err.error || 'Speichern fehlgeschlagen');
          }
          return res.json();
        },
      };
    }
    const p = props as MenuModeProps;
    return {
      mode: 'menu' as const,
      load: async () => {
        const res = await fetch(`/api/v1/menus/${p.menuId}/design`);
        if (!res.ok) throw new Error('Laden fehlgeschlagen');
        const data = await res.json();
        return {
          digital: data.designConfig?.digital || data.digital || data,
          analog: data.designConfig?.analog || {},
          overrides: data.savedOverrides?.digital || {},
          analogOverrides: data.savedOverrides?.analog || {},
          templateName: data.templateName || data.designConfig?.digital?.template || 'elegant',
          customTemplates: data.customTemplates || [],
          meta: { name: '', baseType: '', type: 'MENU' },
        };
      },
      save: async (patch: any) => {
        const body: any = { designConfig: {} };
        if (patch.digital !== undefined) body.designConfig.digital = patch.digital;
        if (patch.customTemplates !== undefined) body.designConfig.customTemplates = patch.customTemplates;
        const res = await fetch(`/api/v1/menus/${p.menuId}/design`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error('Speichern fehlgeschlagen');
        return res.json();
      },
    };
  }, [props]);
}

// ─── Main Editor ───
export default function DesignEditor(props: Props) {
  const router = useRouter();
  const api = useApi(props);
  const isTemplateMode = api.mode === 'template';
  const previewPdfUrl = isTemplateMode
    ? ((props as TemplateModeProps).previewPdfUrl ?? null)
    : null;

  const [config, setConfig] = useState<DigitalConfig | null>(null);
  const [analogConfig, setAnalogConfig] = useState<any>(null);
  const [overrides, setOverrides] = useState<any>({});
  const [analogOverrides, setAnalogOverrides] = useState<any>({});
  const [templateName, setTemplateName] = useState('elegant');
  const [customName, setCustomName] = useState('');
  const [customTemplates, setCustomTemplates] = useState<Array<{name: string; overrides: any; baseTemplate: string}>>([]);
  const [activeTab, setActiveTab] = useState(TABS[0].id);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [savedAt, setSavedAt] = useState<number | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [previewMode, setPreviewMode] = useState<'mobile' | 'desktop' | 'pdf'>('mobile');
  const [showResetDialog, setShowResetDialog] = useState(false);
  const [showTemplateSwitch, setShowTemplateSwitch] = useState<string | null>(null);
  const [templateMetaName, setTemplateMetaName] = useState<string>(isTemplateMode ? (props as TemplateModeProps).initialName : '');

  const iframeRef = useRef<HTMLIFrameElement>(null);
  const saveTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const refreshTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);

  const hasCustomOverrides = useMemo(() => {
    if (!overrides || typeof overrides !== 'object') return false;
    const keys = Object.keys(overrides).filter(k => k !== 'template');
    if (keys.length === 0) return false;
    return keys.some(k => {
      const val = overrides[k];
      if (val === null || val === undefined) return false;
      if (typeof val === 'object' && Object.keys(val).length === 0) return false;
      return true;
    });
  }, [overrides]);

  // Load config
  useEffect(() => {
    let active = true;
    api.load().then(data => {
      if (!active) return;
      setConfig(data.digital as DigitalConfig);
      setAnalogConfig((data as any).analog || {});
      setOverrides(data.overrides);
      setAnalogOverrides((data as any).analogOverrides || {});
      setTemplateName(data.templateName);
      setCustomName(data.overrides?.customName || '');
      setCustomTemplates(data.customTemplates);
      if (isTemplateMode) setTemplateMetaName(data.meta.name);
      setLoading(false);
    }).catch(e => {
      setError(e.message);
      setLoading(false);
    });
    return () => { active = false; };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  // Debounced save (digital overrides)
  const scheduleSave = useCallback((newOverrides: any) => {
    if (saveTimerRef.current) clearTimeout(saveTimerRef.current);
    saveTimerRef.current = setTimeout(async () => {
      setSaving(true);
      setError(null);
      try {
        await api.save({ digital: newOverrides });
        setSavedAt(Date.now());
        if (refreshTimerRef.current) clearTimeout(refreshTimerRef.current);
        refreshTimerRef.current = setTimeout(() => {
          if (iframeRef.current) iframeRef.current.src = iframeRef.current.src;
        }, 150);
      } catch (e: any) {
        setError(e.message || 'Speichern fehlgeschlagen');
      } finally {
        setSaving(false);
      }
    }, 800);
  }, [api]);

  // ─── Analog (PDF) Save + Update ───
  const scheduleSaveAnalog = useCallback((newAnalogOverrides: any) => {
    if (saveTimerRef.current) clearTimeout(saveTimerRef.current);
    saveTimerRef.current = setTimeout(async () => {
      setSaving(true);
      setError(null);
      try {
        await api.save({ analog: newAnalogOverrides });
        setSavedAt(Date.now());
      } catch (e: any) {
        setError(e.message || 'Speichern fehlgeschlagen');
      } finally {
        setSaving(false);
      }
    }, 800);
  }, [api]);

  const updateAnalog = useCallback((path: string, value: any) => {
    setAnalogConfig((prev: any) => {
      const next = JSON.parse(JSON.stringify(prev || {}));
      const parts = path.split('.');
      let obj: any = next;
      for (let i = 0; i < parts.length - 1; i++) {
        if (!obj[parts[i]]) obj[parts[i]] = {};
        obj = obj[parts[i]];
      }
      obj[parts[parts.length - 1]] = value;
      return next;
    });
    setAnalogOverrides((prev: any) => {
      const next = JSON.parse(JSON.stringify(prev || {}));
      const parts = path.split('.');
      let obj: any = next;
      for (let i = 0; i < parts.length - 1; i++) {
        if (!obj[parts[i]]) obj[parts[i]] = {};
        obj = obj[parts[i]];
      }
      obj[parts[parts.length - 1]] = value;
      scheduleSaveAnalog(next);
      return next;
    });
  }, [scheduleSaveAnalog]);

  const updateConfig = useCallback((path: string, value: any) => {
    setConfig(prev => {
      if (!prev) return prev;
      const next = JSON.parse(JSON.stringify(prev));
      const parts = path.split('.');
      let obj: any = next;
      for (let i = 0; i < parts.length - 1; i++) {
        if (!obj[parts[i]]) obj[parts[i]] = {};
        obj = obj[parts[i]];
      }
      obj[parts[parts.length - 1]] = value;
      return next;
    });
    setOverrides((prev: any) => {
      const next = JSON.parse(JSON.stringify(prev || {}));
      const parts = path.split('.');
      let obj: any = next;
      for (let i = 0; i < parts.length - 1; i++) {
        if (!obj[parts[i]]) obj[parts[i]] = {};
        obj = obj[parts[i]];
      }
      obj[parts[parts.length - 1]] = value;
      scheduleSave(next);
      return next;
    });
  }, [scheduleSave]);

  // Template switch
  const handleTemplateClick = useCallback((name: string) => {
    if (hasCustomOverrides) setShowTemplateSwitch(name);
    else switchTemplate(name);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [hasCustomOverrides]);

  const switchTemplate = useCallback(async (name: string) => {
    setShowTemplateSwitch(null);
    setTemplateName(name);
    setSaving(true);
    try {
      if (isTemplateMode) {
        await api.save({ baseType: name, digital: { template: name } });
      } else {
        await api.save({ digital: { template: name } });
      }
      const reloaded = await api.load();
      setConfig(reloaded.digital as DigitalConfig);
      setOverrides(reloaded.overrides);
      setSavedAt(Date.now());
      if (iframeRef.current) iframeRef.current.src = iframeRef.current.src;
    } catch (e: any) {
      setError(e.message);
    } finally {
      setSaving(false);
    }
  }, [api, isTemplateMode]);

  const saveAsCustomTemplate = useCallback(async (name: string) => {
    if (isTemplateMode) return; // not applicable
    if (customTemplates.length >= 4) return;
    const tmpl = {
      name: name || 'Benutzerdefiniert ' + (customTemplates.length + 1),
      overrides: JSON.parse(JSON.stringify(overrides)),
      baseTemplate: templateName,
    };
    const updated = [...customTemplates, tmpl];
    setCustomTemplates(updated);
    try {
      await api.save({ customTemplates: updated });
      setSavedAt(Date.now());
    } catch (e: any) {
      setError(e.message);
    }
  }, [api, customTemplates, overrides, templateName, isTemplateMode]);

  const loadCustomTemplate = useCallback(async (index: number) => {
    const tmpl = customTemplates[index];
    if (!tmpl) return;
    setSaving(true);
    try {
      await api.save({ digital: { ...tmpl.overrides, template: tmpl.baseTemplate } });
      const reloaded = await api.load();
      setConfig(reloaded.digital as DigitalConfig);
      setOverrides(tmpl.overrides);
      setTemplateName(tmpl.baseTemplate);
      setCustomName(tmpl.name);
      setSavedAt(Date.now());
      if (iframeRef.current) iframeRef.current.src = iframeRef.current.src;
    } catch (e: any) {
      setError(e.message);
    } finally {
      setSaving(false);
    }
  }, [api, customTemplates]);

  const deleteCustomTemplate = useCallback(async (index: number) => {
    const updated = customTemplates.filter((_, i) => i !== index);
    setCustomTemplates(updated);
    try {
      await api.save({ customTemplates: updated });
    } catch (e: any) {
      setError(e.message);
    }
  }, [api, customTemplates]);

  const resetToDefaults = useCallback(async () => {
    setSaving(true);
    setShowResetDialog(false);
    try {
      await api.save({ digital: { template: templateName } });
      const reloaded = await api.load();
      setConfig(reloaded.digital as DigitalConfig);
      setOverrides({ template: templateName });
      setCustomName('');
      setSavedAt(Date.now());
      if (iframeRef.current) iframeRef.current.src = iframeRef.current.src;
    } catch (e: any) {
      setError(e.message);
    } finally {
      setSaving(false);
    }
  }, [api, templateName]);

  // Template name editing (template-mode only)
  const updateTemplateMetaName = useCallback(async (newName: string) => {
    setTemplateMetaName(newName);
    if (saveTimerRef.current) clearTimeout(saveTimerRef.current);
    saveTimerRef.current = setTimeout(async () => {
      setSaving(true);
      try {
        await api.save({ name: newName });
        setSavedAt(Date.now());
      } catch (e: any) {
        setError(e.message);
      } finally {
        setSaving(false);
      }
    }, 800);
  }, [api]);

  // Keyboard: Strg+S manually triggers save, Esc closes dialogs
  useEffect(() => {
    const onKey = (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        if (saveTimerRef.current) {
          clearTimeout(saveTimerRef.current);
          saveTimerRef.current = null;
          scheduleSave(overrides);
        }
      }
      if (e.key === 'Escape') {
        setShowResetDialog(false);
        setShowTemplateSwitch(null);
      }
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [overrides, scheduleSave]);

  if (loading) {
    return (
      <div className="flex items-center justify-center py-20">
        <div className="h-10 w-10 rounded-full border-2 border-gray-200 border-t-transparent animate-spin" style={{ borderTopColor: PRIMARY }} />
      </div>
    );
  }
  if (!config) return <div className="p-6 text-red-500">Fehler beim Laden der Design-Konfiguration.</div>;

  const previewUrl = isTemplateMode
    ? (props as TemplateModeProps).previewUrl
    : `/${(props as MenuModeProps).tenantSlug}/${(props as MenuModeProps).locationSlug}/${(props as MenuModeProps).menuSlug}`;

  // ── Status text ──
  let statusText = '';
  let statusTone: 'neutral' | 'active' | 'success' | 'error' = 'neutral';
  if (error) { statusText = error; statusTone = 'error'; }
  else if (saving) { statusText = 'Speichert …'; statusTone = 'active'; }
  else if (savedAt && Date.now() - savedAt < 2000) { statusText = 'Gespeichert'; statusTone = 'success'; }
  else { statusText = 'Änderungen werden automatisch gespeichert'; statusTone = 'neutral'; }

  return (
    <div className="flex h-[calc(100vh-64px)] bg-gray-50">
      {/* LEFT: Editor Panel */}
      <div className="w-[460px] min-w-[420px] flex flex-col border-r border-gray-100 bg-white">

        {/* TopBar */}
        <div className="sticky top-0 z-20 bg-white border-b border-gray-100">
          <div className="flex items-center gap-3 px-4 py-3">
            <button
              onClick={() => router.back()}
              className="rounded-lg p-1.5 hover:bg-gray-100"
              aria-label="Zurück"
            >
              <span className="material-symbols-outlined" style={{ fontSize: 20 }}>arrow_back</span>
            </button>
            <div className="flex-1 min-w-0">
              {isTemplateMode ? (
                <input
                  value={templateMetaName}
                  onChange={e => updateTemplateMetaName(e.target.value)}
                  className="w-full text-base font-bold outline-none border-b border-transparent hover:border-gray-200 focus:border-gray-400 py-0.5"
                  style={{ fontFamily: "'Playfair Display', serif" }}
                  placeholder="Name der Vorlage"
                />
              ) : (
                <h1 className="text-base font-bold truncate" style={{ fontFamily: "'Playfair Display', serif" }}>Design-Editor</h1>
              )}
              <div className="mt-0.5 flex items-center gap-1.5 text-xs">
                <StatusDot tone={statusTone} />
                <span className={statusTone === 'error' ? 'text-red-600' : 'text-gray-500'}>{statusText}</span>
              </div>
            </div>
            <button
              onClick={() => setShowResetDialog(true)}
              className="rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-50"
              title="Alle Anpassungen auf Vorlage-Standard zurücksetzen"
            >
              Zurücksetzen
            </button>
          </div>

          {/* Tab navigation */}
          <div className="px-2">
            <div className="flex flex-wrap gap-1">
              {TABS.map(t => {
                const active = activeTab === t.id;
                return (
                  <button
                    key={t.id}
                    onClick={() => setActiveTab(t.id)}
                    className="flex items-center gap-1 whitespace-nowrap rounded-t-lg px-2.5 py-1.5 text-xs font-medium transition-colors"
                    style={{
                      color: active ? PRIMARY : '#6B7280',
                      borderBottom: active ? `2px solid ${PRIMARY}` : '2px solid transparent',
                      backgroundColor: active ? PRIMARY_SOFT : 'transparent',
                    }}
                  >
                    <span className="material-symbols-outlined" style={{ fontSize: 16 }}>{t.icon}</span>
                    {t.label}
                  </button>
                );
              })}
            </div>
          </div>
        </div>

        {/* Dialogs */}
        <ConfirmDialog open={showResetDialog} title="Design zurücksetzen?" message="Alle individuellen Anpassungen werden verworfen und die Einstellungen der aktuellen Vorlage wiederhergestellt. Dieser Vorgang kann nicht rückgängig gemacht werden." confirmLabel="Zurücksetzen" onConfirm={resetToDefaults} onCancel={() => setShowResetDialog(false)} />
        <ConfirmDialog open={showTemplateSwitch !== null} title="Vorlage wechseln?" message="Sie haben individuelle Anpassungen vorgenommen. Beim Wechsel zu einer anderen Vorlage gehen alle Änderungen verloren und werden durch die Standard-Einstellungen der neuen Vorlage ersetzt." confirmLabel="Vorlage wechseln" onConfirm={() => showTemplateSwitch && switchTemplate(showTemplateSwitch)} onCancel={() => setShowTemplateSwitch(null)} />

        {/* Tab content */}
        <div className="flex-1 overflow-y-auto px-4 py-5 space-y-5">
          {activeTab === 'vorlage' && (
            <TabVorlage
              config={config}
              templateName={templateName}
              hasCustomOverrides={hasCustomOverrides}
              customName={customName}
              setCustomName={(v: string) => { setCustomName(v); updateConfig('customName', v); }}
              customTemplates={customTemplates}
              isTemplateMode={isTemplateMode}
              onTemplateClick={handleTemplateClick}
              onLoadCustom={loadCustomTemplate}
              onDeleteCustom={deleteCustomTemplate}
              onSaveAsCustom={saveAsCustomTemplate}
              update={updateConfig}
