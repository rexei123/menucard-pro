          {activeTab === 'pdf' && !isTemplateMode && (
            <div className="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
              <div className="font-medium mb-1">PDF-Layout nur in Vorlagen verfügbar</div>
