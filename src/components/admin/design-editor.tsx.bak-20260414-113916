          {config.navigation?.showToc && (
            <>
              <SelectInput label="Position" value={config.navigation?.tocPosition || 'sticky'} onChange={(v: string) => update('navigation.tocPosition', v)}
                options={[{ label: 'Oben unter Header', value: 'top' }, { label: 'Sticky', value: 'sticky' }, { label: 'Dropdown', value: 'dropdown' }]} />
              <SelectInput label="Stil" value={config.navigation?.tocStyle || 'pills'} onChange={(v: string) => update('navigation.tocStyle', v)}
                options={[{ label: 'Pill-Buttons', value: 'pills' }, { label: 'Tabs', value: 'tabs' }, { label: 'Einfache Liste', value: 'list' }]} />
            </>
          )}
        </div>
      </section>
      <section>
        <SectionTitle>Verhalten</SectionTitle>
        <div className="space-y-1">
          <Toggle label="Sticky Navigation" checked={config.navigation?.stickyNav ?? true} onChange={(v: boolean) => update('navigation.stickyNav', v)} />
          <Toggle label="Smooth Scroll" checked={config.navigation?.smoothScroll ?? true} onChange={(v: boolean) => update('navigation.smoothScroll', v)} />
          <Toggle label="Aktive Sektion hervorheben" checked={config.navigation?.highlightActive ?? true} onChange={(v: boolean) => update('navigation.highlightActive', v)} />
          <Toggle label="'Nach oben' Button" checked={config.navigation?.showBackToTop ?? true} onChange={(v: boolean) => update('navigation.showBackToTop', v)} />
          <Toggle label="Leere Sektionen ausblenden" checked={config.navigation?.hideEmptySections ?? true} onChange={(v: boolean) => update('navigation.hideEmptySections', v)} />
        </div>
      </section>
    </div>
  );
}

function TabRahmen({ config, update }: any) {
  return (
    <div className="space-y-5">
      <section>
        <SectionTitle>Kopfbereich</SectionTitle>
        <div className="space-y-3">
          <SelectInput label="Logo Position" value={config.header?.logoPosition || 'center'} onChange={(v: string) => update('header.logoPosition', v)}
            options={[{ label: 'Links', value: 'left' }, { label: 'Zentriert', value: 'center' }, { label: 'Rechts', value: 'right' }]} />
          <SliderInput label="Logo Größe" value={config.header?.logoSize || 120} min={40} max={240} unit="px" onChange={(v: number) => update('header.logoSize', v)} />
          <div>
            <Label>Titel (leer = Kartenname)</Label>
            <input type="text" value={config.header?.title || ''} placeholder="Kartenname wird verwendet"
              onChange={e => update('header.title', e.target.value || null)}
              className="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm outline-none focus:border-gray-400" />
          </div>
          <div>
            <Label>Untertitel</Label>
            <input type="text" value={config.header?.subtitle || ''} placeholder="z.B. Saison 2025/26"
              onChange={e => update('header.subtitle', e.target.value || null)}
              className="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm outline-none focus:border-gray-400" />
          </div>
          <SliderInput label="Overlay Opacity" value={(config.header?.overlayOpacity || 0.6) * 100} min={0} max={100} unit="%" onChange={(v: number) => update('header.overlayOpacity', v / 100)} />
          <SelectInput label="Header-Höhe" value={config.header?.height || 'normal'} onChange={(v: string) => update('header.height', v)}
            options={[
              { label: 'Klein (nur Logo+Titel)', value: 'small' },
              { label: 'Normal (Logo+Titel+Untertitel)', value: 'normal' },
              { label: 'Groß (Vollbild mit Hintergrundbild)', value: 'large' },
            ]} />
        </div>
      </section>
      <section>
        <SectionTitle>Fußzeile</SectionTitle>
        <div className="space-y-3">
          <Toggle label="Fußzeile anzeigen" checked={config.footer?.show ?? true} onChange={(v: boolean) => update('footer.show', v)} />
          {config.footer?.show && (
            <>
              <div>
                <Label>Fußzeilen-Text</Label>
                <input type="text" value={config.footer?.text || ''} onChange={e => update('footer.text', e.target.value)}
                  className="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm outline-none focus:border-gray-400" />
              </div>
              <Toggle label="Allergen-Hinweis" checked={config.footer?.showAllergenNote ?? true} onChange={(v: boolean) => update('footer.showAllergenNote', v)} />
              <Toggle label="Preishinweis" checked={config.footer?.showPriceNote ?? true} onChange={(v: boolean) => update('footer.showPriceNote', v)} />
            </>
          )}
        </div>
      </section>
    </div>
  );
}

function SectionTitle({ children }: { children: React.ReactNode }) {
  return <h3 className="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">{children}</h3>;
}
