        <div className="flex items-center justify-between border-b border-gray-100 bg-white px-4 py-2.5">
          <div className="flex flex-wrap gap-1">
            <PreviewToggle active={previewMode === 'mobile'} onClick={() => setPreviewMode('mobile')} icon="smartphone" label="Handy" />
            <PreviewToggle active={previewMode === 'desktop'} onClick={() => setPreviewMode('desktop')} icon="desktop_windows" label="Desktop" />
            {previewPdfUrl && (
              <PreviewToggle active={previewMode === 'pdf'} onClick={() => setPreviewMode('pdf')} icon="picture_as_pdf" label="PDF" />
            )}
          </div>
          {(previewMode === 'pdf' ? previewPdfUrl : previewUrl) && (
            <a href={(previewMode === 'pdf' ? previewPdfUrl : previewUrl) || '#'} target="_blank" rel="noopener noreferrer" className="text-xs font-medium flex items-center gap-1 hover:underline" style={{ color: PRIMARY }}>
              In neuem Tab öffnen
              <span className="material-symbols-outlined" style={{ fontSize: 14 }}>open_in_new</span>
            </a>
          )}
        </div>
        <div className="flex-1 flex items-start justify-center overflow-auto p-6 bg-gray-100">
          {previewMode === 'pdf' && previewPdfUrl ? (
            <div className="bg-white shadow-xl rounded-2xl overflow-hidden w-full max-w-[900px]"
              style={{ height: 'calc(100vh - 180px)' }}>
              <iframe ref={iframeRef} src={`/pdf-viewer.html?url=${encodeURIComponent(previewPdfUrl || '')}&t=${savedAt || 0}`} className="w-full h-full border-0" title="PDF-Vorschau" />
            </div>
          ) : previewUrl ? (
            <div className={`bg-white shadow-xl rounded-2xl overflow-hidden ${previewMode === 'mobile' ? 'w-[390px]' : 'w-full max-w-[1280px]'}`}
              style={{ height: previewMode === 'mobile' ? '780px' : 'calc(100vh - 180px)' }}>
              <iframe ref={iframeRef} src={previewUrl} className="w-full h-full border-0" title="Vorschau" />
            </div>
          ) : (
            <div className="flex flex-col items-center justify-center text-center text-gray-500 mt-24">
              <span className="material-symbols-outlined" style={{ fontSize: 48, color: '#D1D5DB' }}>web_asset_off</span>
              <p className="mt-3 text-sm">Keine Karte nutzt diese Vorlage aktuell.</p>
