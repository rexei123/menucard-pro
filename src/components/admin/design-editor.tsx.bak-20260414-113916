          )}
          {activeTab === 'typografie' && <TabTypografie config={config} update={updateConfig} />}
          {activeTab === 'farben' && <TabFarben config={config} update={updateConfig} />}
          {activeTab === 'produkte' && <TabProdukte config={config} update={updateConfig} />}
          {activeTab === 'elemente' && <TabElemente config={config} update={updateConfig} />}
          {activeTab === 'navigation' && <TabNavigation config={config} update={updateConfig} />}
          {activeTab === 'rahmen' && <TabRahmen config={config} update={updateConfig} />}
